---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import AnnotationLayer from '../components/AnnotationLayer.astro';
import LoreSidebar from '../components/LoreSidebar.astro';
import LoreHydrator from '../components/LoreHydrator';
import { withBasePath } from '../lib/base-path';

export async function getStaticPaths() {
  const entries = await getCollection('lore');

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

const entries = (await getCollection('lore')).sort((left, right) => left.data.order - right.data.order);
const { entry } = Astro.props;

const chars = await getCollection('characters');
const factions = await getCollection('factions');

const charData = chars.map(c => ({ id: c.id, ...c.data }));
const factionData = factions.map(f => ({ id: f.id, ...f.data }));

const currentIndex = entries.findIndex((item) => item.id === entry.id);
const previousEntry = currentIndex > 0 ? entries[currentIndex - 1] : null;
const nextEntry = currentIndex >= 0 && currentIndex < entries.length - 1 ? entries[currentIndex + 1] : null;

const { Content, headings } = await render(entry);

const toLoreHref = (slug: string) => withBasePath(`${slug}/`);
---

<BaseLayout
	title={entry.data.title}
	description={entry.data.subtitle ?? `Раздел ${entry.data.title} в публичной вики мира WOER.`}
>
	<main class="mx-auto max-w-[96rem] px-6 py-8 md:py-10">
		<div class="grid gap-10 xl:grid-cols-[18rem_minmax(0,1fr)_22rem] xl:items-start">
			<aside class="xl:sticky xl:top-24">
				<LoreSidebar entries={entries} currentId={entry.id} headings={headings} />
			</aside>

			<article class="min-w-0">
				<div class="border-b border-[color:rgba(var(--line-rgb),0.12)] pb-8">
					<a href={withBasePath()} class="button-secondary inline-flex">
						Ко всем разделам
					</a>
					<p class="section-kicker mt-6">
						{entry.data.emoji ? `${entry.data.emoji} · ` : ''}
						Раздел {entry.data.order.toString().padStart(2, '0')}
					</p>
					<h1 class="page-title mt-4">{entry.data.title}</h1>
					{entry.data.subtitle && <p class="page-subtitle mt-4">{entry.data.subtitle}</p>}
					<div class="mt-6 flex flex-wrap gap-3">
						{entry.data.sourceFile && <span class="meta-chip">{entry.data.sourceFile}</span>}
						<span class="meta-chip">{headings.length} заголовков</span>
					</div>
				</div>

				<LoreHydrator characters={charData} factions={factionData} client:only="react" />

				<div class="mt-10 lore-content" id="lore-content">
					<Content />
				</div>

				<nav class="mt-14 grid gap-3 border-t border-[color:rgba(var(--line-rgb),0.12)] pt-6 md:grid-cols-2">
					{previousEntry ? (
						<a href={toLoreHref(previousEntry.id)} class="doc-link h-full">
							<p class="doc-source">Назад</p>
							<p class="doc-title mt-3">{previousEntry.data.title}</p>
						</a>
					) : (
						<div />
					)}

					{nextEntry ? (
						<a href={toLoreHref(nextEntry.id)} class="doc-link h-full md:justify-self-end">
							<p class="doc-source">Дальше</p>
							<p class="doc-title mt-3">{nextEntry.data.title}</p>
						</a>
					) : null}
				</nav>
			</article>

			<aside class="xl:sticky xl:top-24">
				<AnnotationLayer pageSlug={entry.id} />
			</aside>
		</div>
	</main>
</BaseLayout>
