---
import '../styles/global.css';
import AuthButton from '../components/AuthButton';
---

<html lang="ru">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Мир Бесконечного Дождя</title>
	</head>
	<body class="min-h-screen bg-neutral-950 text-neutral-100 antialiased">
		<header class="flex items-center justify-end px-6 py-4">
			<AuthButton client:only="react" />
		</header>
		<main class="mx-auto flex min-h-[80vh] max-w-3xl flex-col justify-center px-6 py-16">
			<p class="mb-4 text-sm uppercase tracking-widest text-neutral-500">Hope Rain Punk</p>
			<h1 class="mb-6 font-serif text-5xl font-bold leading-tight md:text-7xl">
				Мир Бесконечного Дождя
			</h1>
			<p class="mb-12 max-w-xl text-lg text-neutral-400">
				Rainpunk-вселенная с вечным дождём, разноцветными молниями и каменными сердцами. Writer's bible в процессе.
			</p>
			<p class="text-sm text-neutral-600">Сайт в разработке. День 1: базовый деплой + Google OAuth.</p>
		</main>
	</body>
</html>