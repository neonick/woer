---
import { basePath } from '../../lib/base-path';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Вход" description="Подтверждение входа в публичную wiki мира WOER.">
	<main class="mx-auto flex min-h-[70vh] max-w-md flex-col items-center justify-center gap-4 px-6 py-16 text-center">
		<div class="surface-panel w-full px-6 py-10">
			<p class="text-sm text-neutral-500">Подтверждаем вход…</p>
			<p id="status" class="mt-3 text-xs text-[color:rgba(var(--muted-rgb),0.94)]"></p>
		</div>
		<script>
			import { supabase } from '../../lib/supabase';
			const status = document.getElementById('status')!;
			supabase.auth.getSession().then(({ data, error }) => {
				if (error) {
					status.textContent = 'Ошибка: ' + error.message;
					return;
				}
				if (data.session) {
					status.textContent = 'Успех. Возвращаемся…';
					setTimeout(() => { window.location.href = `${basePath}`; }, 500);
				} else {
					status.textContent = 'Сессия не найдена. Попробуй снова.';
				}
			});
		</script>
	</main>
</BaseLayout>
