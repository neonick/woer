---
import '../styles/global.css';
import AuthButton from '../components/AuthButton';
import ThemeToggle from '../components/ThemeToggle';
import Search from '../components/Search';
import { withBasePath } from '../lib/base-path';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Мир бесконечного дождя — Hope Rain Punk.",
  ogImage = withBasePath('imgs/triton.png'),
} = Astro.props;

const homeHref = withBasePath();
const faviconHref = withBasePath('favicon.svg');
const headerLogoHref = withBasePath('tumari_logo.svg');
const pageTitle =
  title === 'Мир Бесконечного Дождя' ? title : `${title} — Мир Бесконечного Дождя`;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="ru" data-theme="storm">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		
		<title>{pageTitle}</title>
		<meta name="description" content={description} />

		{/* Open Graph / Facebook */}
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(ogImage, Astro.site)} />

		{/* Twitter */}
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={pageTitle} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(ogImage, Astro.site)} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
		<link rel="icon" type="image/svg+xml" href={faviconHref} />
		<link rel="canonical" href={canonicalURL} />

		<script is:inline>
			(() => {
				try {
					const storedTheme = window.localStorage.getItem('woer-theme');
					const theme = storedTheme === 'mist' ? 'mist' : 'storm';
					document.documentElement.dataset.theme = theme;
					document.documentElement.style.colorScheme = theme === 'mist' ? 'light' : 'dark';
				} catch {
					document.documentElement.dataset.theme = 'storm';
					document.documentElement.style.colorScheme = 'dark';
				}
			})();
		</script>
	</head>
	<body class="min-h-screen bg-[color:rgb(var(--bg-rgb))] text-[color:rgb(var(--text-rgb))] antialiased">
		<header class="border-b border-[color:rgba(var(--line-rgb),0.12)] sticky top-0 z-[100] bg-[color:rgb(var(--bg-rgb))]/80 backdrop-blur-md">
			<div class="mx-auto flex max-w-[88rem] flex-col gap-4 px-6 py-4 md:flex-row md:items-center md:justify-between">
				<div class="min-w-0">
					<a href={homeHref} class="flex max-w-full items-center gap-3 text-[color:rgb(var(--text-rgb))]">
						<img
							src={headerLogoHref}
							alt="Логотип Тумари"
							class="h-12 w-12 shrink-0 rounded-[6px] object-contain"
							loading="eager"
						/>
						<span class="min-w-0 text-sm font-medium">Тумари: Мир Бесконечного Дождя</span>
					</a>
				</div>
				<div class="flex flex-wrap items-stretch gap-3 md:justify-end">
					<Search client:load />
					<div class="h-4 w-px bg-[color:rgba(var(--line-rgb),0.1)] hidden md:block" />
					<ThemeToggle client:only="react" />
					<AuthButton client:only="react" />
				</div>
			</div>
		</header>
		<slot />

		<footer class="border-t border-[color:rgba(var(--line-rgb),0.1)] mt-16">
			<div class="mx-auto max-w-[88rem] px-6 py-8 lg:px-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
				<div class="flex flex-col gap-1">
					<p class="text-xs text-[color:rgba(var(--muted-rgb),0.5)]">
						© 2025 <a href="https://t.me/neonick" target="_blank" rel="noopener" class="hover:text-[color:rgba(var(--muted-rgb),0.9)] transition-colors underline underline-offset-2 decoration-[color:rgba(var(--line-rgb),0.3)]">Николай Марченко</a>
					</p>
					<p class="text-xs text-[color:rgba(var(--muted-rgb),0.5)]">Мир Бесконечного Дождя</p>
				</div>
				<p class="text-xs italic text-[color:rgba(var(--muted-rgb),0.35)]">
					Дождь не прекращается. Работа тоже.
				</p>
			</div>
		</footer>
	</body>
</html>
